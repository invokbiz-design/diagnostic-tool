{
  "version": 2,
  "buildCommand": "CI=false node node_modules/react-scripts/bin/react-scripts.js build",
  "outputDirectory": "build",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}